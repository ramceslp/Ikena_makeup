# Normalize line endings: store LF in the repo, let each OS check out natively.
# Prevents CRLF/LF churn across Windows/macOS/Linux contributors.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text
*.pdf binary
*.ico binary
*.woff binary
*.woff2 binary
