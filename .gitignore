# ── Root .gitignore ───────────────────────────────────────────────
# Per-app ignores live in backend/.gitignore and frontend/.gitignore
# (git honors nested .gitignore files). This file covers root-level
# artifacts and a global safety net for secrets.

# ── Secrets: never commit a real .env (commit .env.example instead) ──
.env
*.env.local

# ── Dependencies (root-level; per-app node_modules ignored in their own dirs) ──
/node_modules/

# ── Local tooling / agent state ────────────────────────────────────
.atl/
.claude/
sdd/

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
